APP_NAME=Gita Learning
APP_ENV=production
DATABASE_URL=postgresql+psycopg://gita_user:change-me@127.0.0.1:5432/gita_learning
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_MINUTES=60
ALLOWED_ORIGINS=https://gita.example.com

MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_BUCKET=gita-learning
MINIO_ACCESS_KEY=replace-minio-access-key
MINIO_SECRET_KEY=replace-minio-secret-key
MAX_UPLOAD_MB=100

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=replace-with-strong-password
ALLOW_LOCAL_SEED_CREDENTIALS=false
